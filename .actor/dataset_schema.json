{
  "actorSpecification": 1,
  "fields": {
    "username": {
      "type": "string",
      "title": "Username",
      "description": "Instagram username"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "description": "Result status (only successful actions appear in dataset)",
      "enum": ["followed", "requested"]
    },
    "success": {
      "type": "boolean",
      "title": "Success",
      "description": "Whether the action was successful (always true in dataset)"
    },
    "reason": {
      "type": "string",
      "title": "Reason",
      "description": "Explanation of the result"
    },
    "timestamp": {
      "type": "string",
      "title": "Timestamp",
      "description": "When the action was performed"
    },
    "runDate": {
      "type": "string",
      "title": "Run Date",
      "description": "ISO timestamp of when the run was executed"
    },
    "accountType": {
      "type": "string",
      "title": "Account Type",
      "description": "Account type setting used for the run (new or mature)"
    }
  },
  "views": {
    "overview": {
      "title": "Follow Results",
      "transformation": {
        "fields": ["username", "status", "reason", "timestamp", "accountType"]
      },
      "display": {
        "component": "table",
        "properties": {
          "username": {
            "label": "Username",
            "format": "text"
          },
          "status": {
            "label": "Status",
            "format": "text"
          },
          "reason": {
            "label": "Reason",
            "format": "text"
          },
          "timestamp": {
            "label": "Timestamp",
            "format": "text"
          },
          "accountType": {
            "label": "Account Type",
            "format": "text"
          }
        }
      }
    }
  }
}
